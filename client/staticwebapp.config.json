{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*.{css,js}", "/public/*", "/*.{png,jpg,svg,ico}"]
  },
  "routes": [
    {
      "route": "/login",
      "rewrite": "/index.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
